APP_NAME=planner-backend
APP_ENV=local
DEBUG=true

SERVER_HOST=0.0.0.0
SERVER_PORT=8001

DATABASE_URL=postgresql+asyncpg://planner:planner@localhost:5432/planner

REDIS_URL=redis://localhost:6379/0

AGENT_EXTRACTED_OBSERVATIONS_STREAM=planner.agent.observations.extracted
AGENT_OBSERVATION_BATCH_READY_STREAM=planner.agent.observations.batch_ready
AGENT_DAY_GENERATION_REQUESTED_STREAM=planner.agent.day_generation.requested

JWT_SECRET=local-dev-jwt-secret
JWT_TTL_SECONDS=86400
INTERNAL_API_TOKEN=local-dev-internal-api-token

TELEGRAM_GATEWAY_SCHEME=http
TELEGRAM_GATEWAY_HOST=localhost
TELEGRAM_GATEWAY_PORT=8000